{
  "name": "smtp-service",
  "private": true,
  "scripts": {
    "dev": "pnpm --parallel --filter @smtp-service/smtp --filter @smtp-service/workers --filter @smtp-service/api --filter @smtp-service/web dev",
    "dev:api": "pnpm --filter @smtp-service/api dev",
    "dev:smtp": "pnpm --filter @smtp-service/smtp dev",
    "dev:workers": "pnpm --filter @smtp-service/workers dev",
    "dev:web": "pnpm --filter @smtp-service/web dev",
    "build": "pnpm -r build",
    "db:generate": "pnpm --filter @smtp-service/db generate",
    "db:migrate": "pnpm --filter @smtp-service/db migrate",
    "db:studio": "pnpm --filter @smtp-service/db studio",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "vitest run",
    "test:watch": "vitest watch"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "dotenv": "^17.4.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
