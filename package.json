{
  "name": "mailpocket",
  "private": true,
  "scripts": {
    "dev": "pnpm --parallel --filter @mailpocket/smtp --filter @mailpocket/workers --filter @mailpocket/api --filter @mailpocket/web dev",
    "dev:api": "pnpm --filter @mailpocket/api dev",
    "dev:smtp": "pnpm --filter @mailpocket/smtp dev",
    "dev:workers": "pnpm --filter @mailpocket/workers dev",
    "dev:web": "pnpm --filter @mailpocket/web dev",
    "build": "pnpm -r build",
    "db:generate": "pnpm --filter @mailpocket/db generate",
    "db:migrate": "pnpm --filter @mailpocket/db migrate",
    "db:studio": "pnpm --filter @mailpocket/db studio",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:e2e": "vitest run tests/e2e/",
    "test:pentest": "vitest run tests/pentest/",
    "test:integration": "vitest run apps/api/tests/api.integration.test.ts",
    "test:matrix:local": "bash scripts/test-matrix-local.sh",
    "test:matrix:local:fast": "bash scripts/test-matrix-local.sh --skip-load",
    "test:security": "vitest run tests/e2e/ tests/pentest/",
    "test:load": "npx artillery run tests/load/api-load.yml",
    "test:load:report": "npx artillery run tests/load/api-load.yml --output load-report.json && npx artillery report load-report.json"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.5.2",
    "dotenv": "^17.4.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
