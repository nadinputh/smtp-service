# ─── SMTP Server ──────────────────────────────────────────
SMTP_PORT=2525
SMTP_HOST=0.0.0.0
# SMTP_PORTS=2525,1025

# ─── API Server ───────────────────────────────────────────
API_PORT=3002
API_HOST=0.0.0.0

# ─── App Mode ─────────────────────────────────────────────
# "testing" = sinkhole (captures all mail, no real delivery)
# "production" = relay (delivers to real recipients via MX lookup)
APP_MODE=testing

# ─── Auth ──────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-random-secret-at-least-16-chars

# ─── OAuth2 PKCE (optional) ───────────────────────────────
OAUTH2_ENABLED=false
# OAUTH2_ISSUER_URL=https://accounts.google.com
# OAUTH2_CLIENT_ID=your-client-id
# OAUTH2_REDIRECT_URI=http://localhost:3000/auth/callback
# OAUTH2_SCOPES=openid profile email

# ─── LDAP (optional) ──────────────────────────────────────
LDAP_ENABLED=false
# LDAP_URL=ldap://localhost:389
# LDAP_BIND_DN=cn=admin,dc=example,dc=com
# LDAP_BIND_PASSWORD=admin_password
# LDAP_SEARCH_BASE=ou=users,dc=example,dc=com
# LDAP_SEARCH_FILTER=(uid={{username}})

# ─── Tracking ─────────────────────────────────────────────
TRACKING_BASE_URL=http://localhost:3002

# ─── Cleanup ──────────────────────────────────────────────
CLEANUP_MAX_AGE_HOURS=24

# ─── Admin Seed (for db:seed script) ─────────────────────
ADMIN_EMAIL=admin@localhost
ADMIN_PASSWORD=changeme
