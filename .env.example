# ─── Redis ─────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=Admin@123456

# ─── MinIO (S3-compatible storage) ─────────────────────────
MINIO_ENDPOINT=localhost
